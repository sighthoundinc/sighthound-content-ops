# research.env — AutoResearch configuration for YOUR project
# Copy this file to research.env and fill in the values.
# research.env is gitignored — it stays local to your machine.

# ── Experiment command ────────────────────────────────────────────────────────
# The shell command that runs one full experiment.
# Must write output (including the metric line) to stdout/stderr.
# Examples:
#   python train.py --epochs 30 --seed 42
#   python -m myproject.train --config config.yaml
#   bash train.sh
TRAIN_CMD="python train.py --epochs 30 --seed 42"

# ── Metric extraction ─────────────────────────────────────────────────────────
# Python regex with ONE capture group that extracts the metric from the log.
# The captured value must be a float.
# Examples:
#   "Test F1=([0-9.]+)"          matches "Test F1=0.847"
#   "val_loss: ([0-9.]+)"        matches "val_loss: 0.231"
#   "accuracy\s*=\s*([0-9.]+)"  matches "accuracy = 0.921"
METRIC_PATTERN="Test F1=([0-9.]+)"

# "higher" — bigger metric is better (F1, accuracy, AUC, R²)
# "lower"  — smaller metric is better (loss, MSE, perplexity)
METRIC_DIRECTION="higher"

# ── Baseline ──────────────────────────────────────────────────────────────────
# The metric value of your current best model.
# The ratchet only commits changes that beat this value.
BASELINE_METRIC="0.500"

# ── Editable files ────────────────────────────────────────────────────────────
# Space-separated list of files the agent is allowed to modify.
# On a failed experiment, only these files are restored.
# Everything else (data, configs, etc.) is never touched.
EDITABLE_FILES="model.py train.py"

# ── Time budget ─────────────────────────────────────────────────────────────────────
# Maximum hours per SESSION. The time limit is enforced at TWO points:
#   1. check-time.sh (soft) — agent checks before each experiment
#   2. run-experiment.sh (hard) — training refuses to start after deadline
# The agent MUST call start-session.sh at the start of each session.
# Default is 2h (a focused session); increase for overnight runs.
# 2h  → ~6 experiments at ~20 min each  (default, safe)
# 8h  → ~24 experiments (overnight)
# 24h → ~72 experiments (full day)
MAX_HOURS=2

# ── Minimum improvement threshold ────────────────────────────────────────────
# A change must improve the metric by at least this much to be kept.
# Prevents committing noise (e.g. 0.001 F1 improvement is not meaningful).
MIN_DELTA=0.005
