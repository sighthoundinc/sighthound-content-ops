# research.env — AutoResearch configuration for the Slack Contract loop.
# This file is gitignored by the sh-autoresearch scripts' default layout; if
# you add it to version control, be aware that autoresearch.sh rewrites the
# BASELINE_METRIC line after each successful iteration.
#
# Goal: ratchet the Slack notification output toward 100% of the contract +
# hardening rules defined in eval/slack/rules.mjs.

# ── Experiment command ────────────────────────────────────────────────────────
# The training command runs the Slack contract scorer and prints one metric
# line that sh-autoresearch greps (slack_contract_pass=<0..1>).
TRAIN_CMD="node scripts/slack-contract-lint.mjs"

# ── Metric extraction ─────────────────────────────────────────────────────────
METRIC_PATTERN="slack_contract_pass=([0-9.]+)"
METRIC_DIRECTION="higher"

# ── Baseline ───────────────────────────────────────────────────────────────────────
# Round 3 baseline. 3 new aspirational fixtures exercise site derivation
# from the linked blog on social events — closing the last caller-side
# bug (H3) surfaced in the deep dive.
BASELINE_METRIC="1.0000"

# ── Editable files ─────────────────────────────────────────────────────────────────
# Round 3 scope. Fixtures and rules stay FROZEN; the agent touches code
# that plumbs site derivation from the linked blog through the emitter +
# callers.
#
# Allowed:
#   - supabase/functions/slack-notify/message.mjs                  (pure message builder)
#   - supabase/functions/slack-notify/index.ts                     (Deno wiring only)
#   - src/lib/server-slack-emitter.ts                              (payload normalization)
#   - src/app/api/social-posts/route.ts                            (caller: social post create)
#   - src/app/api/social-posts/[id]/comments/route.ts              (caller: social comments)
#   - src/app/api/social-posts/[id]/transition/route.ts            (caller: social workflow)
#   - src/app/api/social-posts/reminders/route.ts                  (caller: live-link reminders)
#   - src/app/api/social-posts/overdue-checks/route.ts             (caller: overdue events)
EDITABLE_FILES="supabase/functions/slack-notify/message.mjs supabase/functions/slack-notify/index.ts src/lib/server-slack-emitter.ts src/app/api/social-posts/route.ts src/app/api/social-posts/[id]/comments/route.ts src/app/api/social-posts/[id]/transition/route.ts src/app/api/social-posts/reminders/route.ts src/app/api/social-posts/overdue-checks/route.ts"

# ── Time budget ───────────────────────────────────────────────────────────────
# Per-session budget. Default 2h is plenty; each iteration is seconds.
MAX_HOURS=2

# ── Minimum improvement threshold ─────────────────────────────────────────────
# Aspirational rules weight 5 each on ~27 fixtures; each fixed rule moves the
# metric by roughly 0.01–0.02. 0.005 is just above noise.
MIN_DELTA=0.005
