# Example: PyTorch Image Classifier
# Optimising test F1 on a held-out classification benchmark.

TRAIN_CMD="python train.py --epochs 30 --seed 42 --data-dir data/"
METRIC_PATTERN="Test F1=([0-9.]+)"
METRIC_DIRECTION="higher"
BASELINE_METRIC="0.720"
EDITABLE_FILES="model.py train.py"
MAX_HOURS=8
MIN_DELTA=0.005
