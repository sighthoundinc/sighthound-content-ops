# research.env — autoresearch ratchet config for /login bundle-size optimization.
TRAIN_CMD="./autoresearch/scripts/measure-login-bundle.sh"
METRIC_PATTERN="LOGIN_PAGE_SIZE_KB=([0-9.]+)"
METRIC_DIRECTION="lower"
BASELINE_METRIC="4.450"
EDITABLE_FILES="src/app/login/page.tsx src/app/login/login-page-content.tsx src/app/login/login-hero.tsx src/app/login/login-form.tsx"
MAX_HOURS=1
MIN_DELTA=0.1
