# deft-autoresearch configuration
# Copy to ./autoresearch/research.env and fill in real values.
# This file IS tracked in git (reproducible baselines).

# --- Required -----------------------------------------------------------

# Command that runs ONE experiment and prints the metric somewhere in its
# stdout/stderr. Deterministic, no interactive prompts. Include seeds.
TRAIN_CMD="python scripts/train.py --epochs 30 --seed 42"

# Python regex with exactly ONE capture group that extracts the metric
# from the TRAIN_CMD output. Example metrics:
#   "Test F1=([0-9.]+)"
#   "val_loss: ([0-9.]+)"
#   "bundle size: ([0-9.]+) KB"
METRIC_PATTERN="Test F1=([0-9.]+)"

# "higher" → bigger is better (F1, accuracy, AUC, coverage)
# "lower"  → smaller is better (loss, error, latency, bundle size)
METRIC_DIRECTION="higher"

# Current best metric value. The ratchet only keeps changes that beat this
# by at least MIN_DELTA. Updated by start-session.sh.
BASELINE_METRIC="0.500"

# Space-separated whitelist of files the agent may modify. Evaluation code,
# dataset files, and metric extractors MUST NOT appear here.
EDITABLE_FILES="src/model.py src/train.py"

# --- Verification gate --------------------------------------------------

# VERIFY_CMD runs BEFORE metric extraction on every iteration. Any non-zero
# exit discards the change regardless of metric movement. Default is
# `task check` to align with the Deft pre-commit gate. Override with any
# repo-native command chain (e.g. `npm run check:full`, `pytest -q`).
VERIFY_CMD="task check"

# --- Time budget --------------------------------------------------------

# Session time budget in hours. The soft check is enforced by
# check-time.sh; the hard check is enforced by run-experiment.sh. Both
# read the deadline from autoresearch/sessions/<id>/session.env.
MAX_HOURS=2

# Smallest metric delta treated as a real improvement. Prevents committing
# noise. Scale to the natural resolution of your metric.
MIN_DELTA=0.005

# --- Optional -----------------------------------------------------------

# Tag appended to session directory name. Purely cosmetic.
# Default: auto-generated from the session timestamp.
# SESSION_SLUG="f1-optimization"

# Override the commit subject template for kept experiments.
# Default: "experiment: <description> (<metric_name>=<new_value>)"
# COMMIT_TEMPLATE="experiment: {desc} ({metric}={value})"
